{
    "name": "Gradio Backend Dev",
    "dockerComposeFile": [
        "../docker-compose.yml"
    ],
    "service": "translator_backend",
    "workspaceFolder": "/app",
    "customizations": {
        "vscode": {
            "extensions": [
                "ms-python.python",
                "ms-python.vscode-pylance",
                "charliermarsh.ruff"
            ],
            "settings": {
                // Chỉ định đường dẫn interpreter là venv mà uv đã tạo
                "python.defaultInterpreterPath": "/app/.venv/bin/python",
                "python.terminal.activateEnvironment": true
            }
        }
    },
    // Giữ container chạy ngầm
    "overrideCommand": false,
    // Cấp quyền cho GPU bên trong VS Code Dev Container
    "runArgs": [
        "--gpus",
        "all"
    ]
}